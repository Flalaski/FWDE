\fs28\b Configuration\b0\fs22\par
\par
Settings are in the \f1 Config\f0  map at the top of \f1 FWDE.ahk\f0 .\par
\par

\fs24\b Core Physics\b0\par
\f1 "MinMargin", 2,                    ; Distance from screen edges (px)\par
"MinGap", 21,                      ; Gap between windows\par
"AttractionForce", 0.00005,        ; Pull toward center\par
"RepulsionForce", 0.8,             ; Push apart from other windows\par
"EdgeRepulsionForce", 0.80,        ; Push from screen edges\par
"Damping", 0.001,                  ; Friction coefficient\par
"MaxSpeed", 12.0,                  ; Max velocity\f0\par
\par

\fs24\b Performance\b0\par
\f1 "PhysicsTimeStep", 1,              ; Physics update frequency (ms)\par
"VisualTimeStep", 16,              ; Visual update frequency (ms) - ~60fps\par
"UserMoveTimeout", 11111,          ; Pause after user interaction (ms)\par
"ManualLockDuration", 33333,       ; Lock duration (ms, ~33 seconds)\f0\par
\par

\fs24\b Window Detection\b0\par
\f1 "ForceFloatProcesses", [           ; Always manage these processes\par
    "firefox.exe", "chrome.exe", "cursor.exe", "code.exe",\par
    "notepad++.exe", "devenv.exe", "explorer.exe",\par
    "winword.exe", "excel.exe", "powerpnt.exe", "outlook.exe"\par
],\par
"FloatClassPatterns", [            ; Window classes to include\par
    "MozillaWindowClass", "Chrome_WidgetWin_1", "ApplicationFrameWindow",\par
    "Code.exe", "Cursor.exe", "Notepad", "Notepad++"\par
],\par
"FloatTitlePatterns", [            ; Window titles to include\par
    "VST.*", "JS:.*", "Plugin", "Command Prompt", "Windows Terminal"\par
]\f0\par
\par

\fs24\b Advanced Features\b0\par
\f1 "MultimonitorExpanse", false,         ; Allow windows to float across monitors\par
"TooltipDuration", 15000,              ; Debug tooltip duration (ms)\par
"ResizeDelay", 22,                     ; Delay before physics after resize (ms)\f0\par
\par

\fs28\b Debugging\b0\fs22\par
\par

\fs24\b Tools\b0\par
\bullet  \f1 Ctrl+Alt+D\f0  - Show all tracked/untracked windows with details\par
\bullet  \f1 Ctrl+Alt+I\f0  - Analyze active window (why managed/not managed)\par
\bullet  \f1 Ctrl+Alt+A\f0  - Manually add window to physics\par
\par

\fs24\b Troubleshooting\b0\par
\par
\b Windows not moving\b0\par
1. Check arrangement: \f1 Ctrl+Alt+Space\f0  (must be ON)\par
2. Check physics: \f1 Ctrl+Alt+P\f0  (must be ON)\par
3. Debug window: \f1 Ctrl+Alt+I\f0  on the window\par
4. Force add: \f1 Ctrl+Alt+A\f0  if detection failed\par
\par
\b Too much movement\b0\par
\bullet  Increase damping: \f1 "Damping"\f0  to 0.005+\par
\bullet  Reduce repulsion: \f1 "RepulsionForce"\f0  to 0.3 or less\par
\bullet  Lock windows: \f1 Ctrl+Alt+L\f0  to fix position\par
\par
\b Performance issues\b0\par
\bullet  Increase timesteps: \f1 "PhysicsTimeStep"\f0  to 5, \f1 "VisualTimeStep"\f0  to 33\par
\bullet  Lock unnecessary windows: \f1 Ctrl+Alt+L\f0\par
\par
\b Multi-monitor issues\b0\par
\bullet  Toggle mode: \f1 Ctrl+Alt+M\f0  for multimonitor expanse\par
\bullet  Check detection: \f1 Ctrl+Alt+D\f0  shows monitor assignments\par
\par
\b Window not detected\b0\par
\bullet  Check patterns: \f1 Ctrl+Alt+I\f0  shows which patterns match\par
\bullet  Add to \f1 ForceFloatProcesses\f0 : Add process name to config\par
\bullet  Force add: \f1 Ctrl+Alt+A\f0  for immediate inclusion\par
\par

